// 16x10 regression map reproducing the old Tilemap::test_room() layout.
//
// Left chamber (cols 1-8): pressurised.
// Separating wall (cols 9-10): double-thick.
// Right chamber (cols 11-14): vacuum.
// Perimeter walls on all edges of the 16x10 area.
// Remaining chunk area (cols 16-31, rows 10-31) filled with Wall.
(
    version: 1,
    layers: {
        "tiles": (
            chunk_size: 32,
            keys: {
                0: (kind: Wall),
                1: (kind: Floor),
                2: (kind: Floor, atmosphere: Vacuum),
            },
            chunks: {
                (0, 0): "",
            },
        ),
        "spawns": [
            (position: [6.0, 5.0, 3.0], template: "ball"),
            (position: [4.0, 1.0, 3.0], template: "can"),
            (position: [5.0, 1.0, 3.0], template: "toolbox", contents: ["can"]),
        ],
    },
)
