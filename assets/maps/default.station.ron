// Default 32x32 station map.
//
// Bridge       (rows 1-8,  cols 1-9)   — pressurised command area
// Vacuum Bay   (rows 1-8,  cols 18-30) — sealed vacuum section
// Central Corridor (rows 1-30, cols 11-16) — pressurised spine
// Medbay       (rows 10-17, cols 1-9)  — pressurised
// Cargo Hold   (rows 10-17, cols 18-30)— pressurised, with pillar
// Engineering  (rows 19-30, cols 1-9)  — pressurised, with pillar
// Storage      (rows 19-30, cols 18-30)— pressurised
//
// Doors connect each room to the central corridor and between
// vertically adjacent rooms on each side.
(
    version: 1,
    layers: {
        "tiles": (
            chunk_size: 32,
            keys: {
                0: (kind: Wall),
                1: (kind: Floor),
                2: (kind: Floor, atmosphere: Vacuum),
            },
            chunks: {
                (0, 0): "",
            },
        ),
        "spawns": [
            (position: [5.0, 5.0, 4.0], template: "ball"),
            (position: [3.0, 1.0, 3.0], template: "can"),
            (position: [7.0, 1.0, 4.0], template: "toolbox", contents: ["can"]),
        ],
    },
)
